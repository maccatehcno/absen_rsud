# ========================================
# TEMPLATE KONFIGURASI ENVIRONMENT ROOT
# ========================================
# Peringatan: Jangan menaruh kredensial asli di file ini ke public repository.
# File ini digunakan untuk referensi root atau orkestrasi via docker-compose.

# Konfigurasi Database Configuration (Used by Docker & Backends)
DB_DRIVER=postgres # atau 'mysql'
# PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# MySQL: USER:PASSWORD@tcp(HOST:PORT)/DBNAME?charset=utf8mb4&parseTime=True&loc=Local
DATABASE_URL=postgresql://root:rootpassword@localhost:5432/distritek_db?schema=public
DATABASE_URL_MYSQL="mysql://user:password@tcp(host:port)/dbname?parseTime=true"

# Konfigurasi Autentikasi
JWT_SECRET="your-jwt-secret-key"

# Konfigurasi Port Aplikasi Local
PORT_NESTJS=3000
PORT_GOLANG=4000
PORT_FRONTEND=5173

# Konfigurasi S3 Storage
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_HOST="https://your-s3-host.com"
S3_BUCKET="your-s3-bucket-name"

# Konfigurasi Frontend API Endpoints
VITE_API_URL="http://localhost:3000"
